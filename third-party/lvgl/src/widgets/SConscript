Import('env', 'root_dir')
from ModuleBuild import *

module = 'widgets'  # 模块名，同簇模块不得重名
current_dir = os.path.join(Dir('.').abspath)
target = None


#========================================================
# ram_source_files：运行在ram中
# flash_source_files：运行在flash中
#========================================================
ram_source_files = [

]

flash_source_files = [
    'lv_arc.c',
    'lv_bar.c',
    'lv_btn.c',
    'lv_btnmatrix.c',
    'lv_canvas.c',
    'lv_checkbox.c',
    'lv_dropdown.c',
    'lv_img.c',
    'lv_label.c',
    'lv_line.c',
    'lv_roller.c',
    'lv_slider.c',
    'lv_switch.c',
    'lv_table.c',
    'lv_textarea.c',
]


#========================================================
# public_incs：置于工程环境中，供其他模块引用
# private_incs：仅在本模块中引用
#========================================================
public_incs = [
    
]

private_incs = [
    
]


#========================================================
# cpp_define：仅适用于本模块，对其他模块不可见
#========================================================
cpp_defines = [
]


#========================================================
# 模块编译
#========================================================
mod = ModuleBuild(env,
        name = module,
        ram_srcs = ram_source_files,
        flash_srcs = flash_source_files,
        pub_incs = public_incs,
        pri_incs = private_incs,
        cpp_define = cpp_defines
)

target = mod.build_object()

Return('target')
