Import('env', 'root_dir')
from ModuleBuild import *

module = 'wolfssl'  # 模块名，同簇模块不得重名
current_dir = os.path.join(Dir('.').abspath)
target = None


#========================================================
# ram_source_files：运行在ram中
# flash_source_files：运行在flash中
#========================================================
ram_source_files = [

]

flash_source_files = [
    'wolfssl-3.15.3/wolfcrypt/src/coding.c',
    'wolfssl-3.15.3/wolfcrypt/src/hash.c',
    'wolfssl-3.15.3/wolfcrypt/src/hmac.c',
    'wolfssl-3.15.3/wolfcrypt/src/integer.c',
    'wolfssl-3.15.3/wolfcrypt/src/md5.c',
    'wolfssl-3.15.3/wolfcrypt/src/misc.c',
    'wolfssl-3.15.3/wolfcrypt/src/random.c',
    'wolfssl-3.15.3/wolfcrypt/src/rsa.c',
    'wolfssl-3.15.3/wolfcrypt/src/sha.c',
    'wolfssl-3.15.3/wolfcrypt/src/sha256.c',
    'wolfssl-3.15.3/wolfcrypt/src/wc_port.c',
]


#========================================================
# public_incs：置于工程环境中，供其他模块引用
# private_incs：仅在本模块中引用
#========================================================
public_incs = [
    
]

private_incs = [
    'port',
    'wolfssl-3.15.3',
]


#========================================================
# cpp_define：仅适用于本模块，对其他模块不可见
#========================================================
cpp_defines = [
]


#========================================================
# 模块编译
#========================================================
mod = ModuleBuild(env,
        name = module,
        ram_srcs = ram_source_files,
        flash_srcs = flash_source_files,
        pub_incs = public_incs,
        pri_incs = private_incs,
        cpp_define = cpp_defines
)

target = mod.build_object()

Return('target')
